; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ColourIsWorld"
run/main_scene="uid://b56tmwsv7giv0"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

language_manager="*uid://b42ufs8mbfguw"
save_manager="*uid://rupyqa7gqlhv"

[debug]

gdscript/warnings/unused_parameter=0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

naming/node_name_num_separator=2
naming/default_signal_callback_name="on_{node_name}_{signal_name}"
naming/default_signal_callback_to_self_name="on_{signal_name}"
naming/scene_name_casing=1
naming/script_name_casing=1

[file_customization]

folder_colors={
"res://assets/": "red",
"res://build/": "yellow",
"res://locale/": "blue",
"res://map/": "teal",
"res://prefabs/": "orange",
"res://scenes/": "purple",
"res://scripts/": "gray"
}

[input]

ui_change_to_previous_language={
